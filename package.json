{
  "name": "filterql",
  "version": "3.0.3",
  "description": "A tiny query language for filtering structured data",
  "keywords": [
    "data",
    "filter",
    "filtering",
    "filterql",
    "language",
    "query",
    "typescript"
  ],
  "homepage": "https://github.com/adamhl8/filterql",
  "bugs": {
    "url": "https://github.com/adamhl8/filterql/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhl8/filterql.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "bundle": "nub run lint && tsdown",
    "lint": "markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && oxfmt && oxlint --fix --fix-suggestions --fix-dangerously && adamhl8-knip && vitest run",
    "prepare": "lefthook install",
    "prepublishOnly": "nub run bundle",
    "bump-deps": "rm -f lock.yaml && nub update -L"
  },
  "devDependencies": {
    "@adamhl8/configs": "^0.20.1",
    "@arethetypeswrong/core": "^0.18.4",
    "@types/node": "^26.0.1",
    "knip": "^6.22.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
